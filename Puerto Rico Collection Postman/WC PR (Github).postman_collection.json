    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "var moment = require('moment');",
          "var CryptoJS = require(\"crypto-js\");",
          "var auth = {",
          "    \"login\": pm.collectionVariables.get('login_test'),",
          "    \"tranKey\": pm.collectionVariables.get('secretKey_test')",
          "}",
          "var nonce = Math.random().toString(36).substring(2);",
          "var seed = moment().format()",
          "hash = CryptoJS.SHA256(nonce + seed + auth.tranKey)",
          "auth.tranKey = hash.toString(CryptoJS.enc.Base64)",
          "auth.nonce = btoa(nonce)",
          "auth.seed = seed",
          "pm.collectionVariables.set('auth', JSON.stringify(auth))",
          "",
          "IdRondom = Math.floor(Math.random() * 1000000)",
          "",
          "var exp = moment().add(10, 'minutes')",
          "pm.collectionVariables.set('exp', JSON.stringify(exp))",
          "pm.collectionVariables.set('IdRondom', IdRondom.toString())",
          "console.log(auth, exp)"
        ]
      }
    },
