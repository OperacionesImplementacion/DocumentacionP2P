        "exec": [
          "var moment = require('moment');\r",
          "\r",
          "var CryptoJS = require(\"crypto-js\");\r",
          "\r",
          "var auth = {\r",
          "\r",
          "    \"login\": pm.collectionVariables.get('Login'),\r",
          "    \"tranKey\": pm.collectionVariables.get('secretKey')\r",
          "};\r",
          "\r",
          "var nonce = Math.random().toString(36).substring(2);\r",
          "\r",
          "var seed = moment().format();\r",
          "\r",
          "hash = CryptoJS.SHA256(nonce + seed + auth.tranKey);\r",
          "\r",
          "auth.tranKey = hash.toString(CryptoJS.enc.Base64);\r",
          "\r",
          "auth.nonce = btoa(nonce);\r",
          "\r",
          "auth.seed = seed;\r",
          "\r",
          "pm.environment.set('auth', JSON.stringify(auth));\r",
          "\r",
          "console.log(auth);"
        ]
      }
